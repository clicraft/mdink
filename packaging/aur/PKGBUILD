# Maintainer: mdink contributors
# AUR package for mdink — terminal markdown renderer.
#
# Version placeholder is updated per release.

pkgname=mdink
pkgver=VERSION_PLACEHOLDER
pkgrel=1
pkgdesc="Terminal markdown renderer with syntax highlighting and image support"
arch=('x86_64' 'aarch64')
url="https://github.com/mdink-rs/mdink"
license=('MIT')
makedepends=('cargo')
source=("$pkgname-$pkgver.tar.gz::https://github.com/mdink-rs/mdink/archive/v$pkgver.tar.gz")
sha256sums=('SHA256_PLACEHOLDER')

prepare() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "$pkgname-$pkgver"
    export RUSTUP_TOOLCHAIN=stable
    export CARGO_TARGET_DIR=target
    cargo build --frozen --release
}

package() {
    cd "$pkgname-$pkgver"

    install -Dm755 "target/release/mdink" "$pkgdir/usr/bin/mdink"
    install -Dm644 "LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"

    # Man page
    if [ -f "assets/mdink.1.gz" ]; then
        install -Dm644 "assets/mdink.1.gz" "$pkgdir/usr/share/man/man1/mdink.1.gz"
    fi

    # Shell completions
    if [ -d "assets/completions" ]; then
        install -Dm644 "assets/completions/mdink.bash" \
            "$pkgdir/usr/share/bash-completion/completions/mdink"
        install -Dm644 "assets/completions/_mdink" \
            "$pkgdir/usr/share/zsh/site-functions/_mdink"
        install -Dm644 "assets/completions/mdink.fish" \
            "$pkgdir/usr/share/fish/vendor_completions.d/mdink.fish"
    fi
}
